generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  auth0Id   String   @unique
  email     String
  lists     GroceryList[]
}

model GroceryList {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime
  items     GroceryItem[]
  user      User     @relation(fields: [userId], references: [id])
}

model GroceryItem {
  id        String   @id @default(uuid())
  name      String
  price     Float
  listId    String
  list      GroceryList @relation(fields: [listId], references: [id])
}